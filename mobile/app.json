{
  "expo": {
    "name": "SVBK ERP",
    "slug": "bknr-erp",
    "scheme": "bknrerp",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#f4f7fb",
    "splash": {
      "image": "./assets/brand-dp-3d.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7fbff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bknr.erp",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.bknr.erp",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/brand-dp-3d.png"
      },
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1ed9ceb0-0c30-43d2-b2bc-00c960aafcdc"
      }
    },
    "plugins": [
      "expo-sharing"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1ed9ceb0-0c30-43d2-b2bc-00c960aafcdc"
    }
  }
}
